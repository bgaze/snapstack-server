{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.bgaze/snapstack-server",
  "description": "Local always-on server for SnapStack: browser capture intake + MCP over 127.0.0.1.",
  "version": "1.2.0",
  "repository": {
    "url": "https://github.com/bgaze/snapstack-server",
    "source": "github"
  },
  "websiteUrl": "https://github.com/bgaze/snapstack-extension",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "snapstack-server",
      "version": "1.2.0",
      "runtimeHint": "npx",
      "transport": { "type": "stdio" },
      "packageArguments": [
        { "type": "positional", "value": "snapstack" },
        { "type": "positional", "value": "mcp" }
      ]
    }
  ]
}
